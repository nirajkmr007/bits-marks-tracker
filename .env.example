# Copy to .env (never commit .env). Without these set, the app falls back to
# local file storage under data/marks/ — which is what you want for local dev.

# Fine-grained PAT with "Contents: read & write" on the data repo only.
GITHUB_TOKEN=
# Repo that stores the marks JSON, e.g. nirajkmr007/bits-marks-tracker
GITHUB_DATA_REPO=
GITHUB_DATA_BRANCH=main
